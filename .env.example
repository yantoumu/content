# 多API配置示例
# 将单个API复制多份以启用并发处理
KEYWORDS_API_URLS='["https://your-api-server.com/keywords/", "https://your-api-server.com/keywords/", "https://your-api-server.com/keywords/"]'

# 其他配置保持不变
WEBSITE_URLS='["https://example.com/sitemap.xml"]'
ENCRYPTION_KEY="your-encryption-key-here"
SITEMAP_API_URL="https://your-sitemap-api.com"
SITEMAP_API_KEY="your-sitemap-api-key"
LOGLEVEL=INFO
